# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID администраторов через запятую (можно несколько)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# ── Один канал (старый формат, обратная совместимость) ──
# GROUP_ID=-1001234567890

# ── Несколько каналов: "Название:ID,Название2:ID2" ──
# При использовании GROUPS переменная GROUP_ID не нужна.
# Если указан только один канал — шаг выбора в мастере пропускается.
GROUPS=Основной канал:-1001234567890

# Часовой пояс для отображения времени окончания аукциона
TIMEZONE=Europe/Moscow
