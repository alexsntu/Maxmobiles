# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID администраторов через запятую (можно несколько)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# ID группы/канала где будут публиковаться лоты
# Для группы: -1001234567890 (отрицательное число с -100)
# Узнать ID: добавить @getmyid_bot в группу или переслать сообщение из группы @userinfobot
GROUP_ID=-1001234567890

# Часовой пояс для отображения времени окончания аукциона
TIMEZONE=Europe/Moscow
