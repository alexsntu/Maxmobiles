  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -d .git ]; then if [ -z \"$(git status --porcelain)\" ]; then if git pull --ff-only >/tmp/mm_pull.log 2>&1; then MSG=\"Git pull выполнен успешно.\"; else MSG=\"Git pull не выполнен (возможно расхождение веток) — проверьте вручную: git status\"; fi; else MSG=\"Есть незакоммиченные изменения — git pull пропущен. Сначала сохраните/закоммитьте работу.\"; fi; printf '{\"systemMessage\": \"%s\"}' \"$MSG\"; fi",
            "shell": "bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -d .git ]; then DIRTY=$(git status --porcelain); AHEAD=$(git rev-list @{u}..HEAD --count 2>/dev/null); if [ -n \"$DIRTY\" ]; then printf '{\"systemMessage\": \"Напоминание: есть незакоммиченные изменения. Сделайте git add, commit и push перед завершением работы (особенно если продолжите на другом ПК).\"}'; elif [ -n \"$AHEAD\" ] && [ \"$AHEAD\" -gt 0 ]; then printf '{\"systemMessage\": \"Напоминание: есть закоммиченные, но не отправленные изменения. Не забудьте git push.\"}'; fi; fi",
            "shell": "bash"
          }
        ]
      }
    ]
  }
